# Security headers for the static SPA, served by Cloudflare Workers static assets.
# (Replaces the helmet CSP from the old Express server. 'unsafe-inline' is allowed
# for styles only: React style attributes + the print-view <style> block.)
/*
  Content-Security-Policy: default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; connect-src 'self'; frame-ancestors 'none'; object-src 'none'; base-uri 'self'; form-action 'self'
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
